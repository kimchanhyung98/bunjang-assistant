{
  "name": "bunjang-assistant",
  "version": "0.4.0",
  "private": true,
  "description": "Bunjang assistant for Codex and Claude on macOS — market price lookup, listing search and ranking, chat and favorites management, and sales draft generation.",
  "type": "module",
  "bin": {
    "bunjang-assistant": "./install/bunjang-assistant-install.mjs",
    "bunjang-assistant-install": "./install/bunjang-assistant-install.mjs",
    "bunjang-assistant-run": "./src/index.js"
  },
  "scripts": {
    "bunjang": "node src/index.js",
    "test": "node --test test/*.test.js",
    "check": "npm test"
  },
  "dependencies": {
    "bunjang-cli": "0.2.1"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "plugin.json",
    ".agents/plugins/marketplace.json",
    ".codex-plugin/**",
    ".claude-plugin/**",
    "commands/**",
    "docs/**",
    "install/**",
    "skills/bunjang/**",
    "src/**"
  ],
  "keywords": [
    "bunjang",
    "bunjang-cli",
    "bunjang-assistant",
    "bunjang-tool",
    "bunjang-tools",
    "번개장터툴",
    "번개장터도구",
    "codex-plugin",
    "claude-plugin",
    "agent-toolkit"
  ]
}
